# AUTO-GENERATED from docker/Dockerfile.j2 — do not edit directly.
# Regenerate with: nox -s docker-gen
# Variant: {{ variant_name }}

# =============================================================================
# Stage 1: Build — install prod-only deps, build clean venv
# =============================================================================
FROM {{ build_base_image }} AS build

# Security patching (layer is cached and reused by prod stage)
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends --only-upgrade libc6 libc-bin libsqlite3-0 zlib1g \
    && rm -rf /var/lib/apt/lists/*

# Copy uv binary from official image (pin version for reproducibility)
COPY --from=ghcr.io/astral-sh/uv:{{ uv_version }} /uv /uvx /bin/

# Install Python {{ python_version }} to /opt/python (accessible by all users)
ENV UV_PYTHON_INSTALL_DIR=/opt/python
RUN uv python install {{ python_version }}

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN touch README.md

# Install ONLY production dependencies
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev {{ extras_flags }} --no-install-project

# =============================================================================
# Stage 2: Test — extend build with dev deps, run nox, validate code
# =============================================================================
FROM build AS test

COPY pyproject.toml uv.lock noxfile.py ./

# Add dev dependencies on top of prod venv
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --group dev {{ extras_flags }} --no-install-project

ENV PATH="/app/.venv/bin:$PATH"

COPY src/ ./src/
COPY tests/ ./tests/
COPY config/ ./config/

# Create non-root user for test stage
RUN useradd --create-home --shell /bin/bash dataeval \
    && chown -R dataeval:dataeval /app

USER dataeval

# -------------------------------------------------------
# CI GATE: Run Tests & Linting
# If this fails, the Docker build fails — nothing is published.
# -------------------------------------------------------
RUN nox

# =============================================================================
# Stage 3: Production — clean image with only what's needed to run
# =============================================================================
FROM {{ prod_base_image }} AS prod

# Patch OS-level vulnerabilities from base image
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends --only-upgrade libc6 libc-bin libsqlite3-0 zlib1g \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user early for --chown on COPY
RUN useradd --create-home --shell /bin/bash dataeval \
    && mkdir -p /dataeval /output /cache \
    && touch /dataeval/.not_mounted /output/.not_mounted \
    && chown -R dataeval:dataeval /dataeval /output /cache

WORKDIR /app

# Copy pre-built artifacts from build (prod deps only — no dev tools)
COPY --from=build /opt/python /opt/python
COPY --from=build --chown=dataeval:dataeval /app/.venv /app/.venv
COPY --chown=dataeval:dataeval src/ ./src/
COPY --chown=dataeval:dataeval entrypoint.sh ./
RUN chmod +x entrypoint.sh

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app/src"

# Container labels
LABEL org.opencontainers.image.title="{{ label_title }}" \
      org.opencontainers.image.description="{{ label_description }}" \
      org.opencontainers.image.version="{{ version }}" \
      org.opencontainers.image.source="https://gitlab.jatic.net/jatic/aria/dataeval-flow"

{% if security_patches %}
# Security patching: purge flagged OS packages
{% for patch in security_patches %}
RUN {{ patch }}
{% endfor %}
{% endif %}
USER dataeval

ENV UV_EXTRAS_OVERRIDE={{ variant_name }}
ENV CONTAINER_MODE={{ "cpu" if variant_name == "cpu" else "gpu" }}
ENV DATAEVAL_DATA=/dataeval

ENTRYPOINT ["./entrypoint.sh"]
CMD ["python", "src/container_run.py"]
