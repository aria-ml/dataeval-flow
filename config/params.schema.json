{
  "$defs": {
    "BoVWExtractorConfig": {
      "description": "BoVWExtractor configuration. No model file required.",
      "properties": {
        "type": {
          "const": "bovw",
          "default": "bovw",
          "title": "Type",
          "type": "string"
        },
        "vocab_size": {
          "default": 2048,
          "description": "Visual word count.",
          "maximum": 4096,
          "minimum": 256,
          "title": "Vocab Size",
          "type": "integer"
        }
      },
      "title": "BoVWExtractorConfig",
      "type": "object"
    },
    "DataCleaningParameters": {
      "description": "Parameters for data cleaning workflow.\n\nRequired parameters must be explicitly set per CR-4.14-G-1\n(avoid application-specific defaults).",
      "properties": {
        "mode": {
          "default": "advisory",
          "description": "advisory: report only, preparatory: modify dataset",
          "enum": [
            "advisory",
            "preparatory"
          ],
          "title": "Mode",
          "type": "string"
        },
        "outlier_method": {
          "description": "Statistical method for outlier detection",
          "enum": [
            "adaptive",
            "zscore",
            "modzscore",
            "iqr"
          ],
          "title": "Outlier Method",
          "type": "string"
        },
        "outlier_flags": {
          "description": "Image statistics groups for outlier detection. At least one required.",
          "items": {
            "enum": [
              "dimension",
              "pixel",
              "visual"
            ],
            "type": "string"
          },
          "minItems": 1,
          "title": "Outlier Flags",
          "type": "array"
        },
        "outlier_threshold": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Custom threshold (None = use DataEval default for chosen method)",
          "title": "Outlier Threshold"
        },
        "outlier_cluster_threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Std devs from cluster center to flag as outlier (requires extractor). None = skip cluster detection.",
          "title": "Outlier Cluster Threshold"
        },
        "outlier_cluster_algorithm": {
          "anyOf": [
            {
              "enum": [
                "kmeans",
                "hdbscan"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Clustering algorithm for cluster-based outlier detection.",
          "title": "Outlier Cluster Algorithm"
        },
        "outlier_n_clusters": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Expected number of clusters. None = auto-detect.",
          "title": "Outlier N Clusters"
        },
        "duplicate_flags": {
          "anyOf": [
            {
              "items": {
                "enum": [
                  "hash_basic",
                  "hash_d4"
                ],
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Hash flag groups for duplicate detection. None = DataEval default (hash_basic: xxhash + phash + dhash).",
          "title": "Duplicate Flags"
        },
        "duplicate_merge_near": {
          "default": true,
          "description": "Merge overlapping near-duplicate groups from different detection methods.",
          "title": "Duplicate Merge Near",
          "type": "boolean"
        },
        "duplicate_cluster_sensitivity": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Threshold for cluster-based near duplicate detection (requires extractor). None = skip cluster detection.",
          "title": "Duplicate Cluster Sensitivity"
        },
        "duplicate_cluster_algorithm": {
          "anyOf": [
            {
              "enum": [
                "kmeans",
                "hdbscan"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Clustering algorithm for cluster-based duplicate detection.",
          "title": "Duplicate Cluster Algorithm"
        },
        "duplicate_n_clusters": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Expected number of clusters for duplicate detection. None = auto-detect.",
          "title": "Duplicate N Clusters"
        }
      },
      "required": [
        "outlier_method",
        "outlier_flags"
      ],
      "title": "DataCleaningParameters",
      "type": "object"
    },
    "DatasetConfig": {
      "description": "Dataset configuration schema.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "format": {
          "enum": [
            "huggingface",
            "coco",
            "yolo",
            "image_folder"
          ],
          "title": "Format",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "split": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Split"
        },
        "recursive": {
          "default": false,
          "title": "Recursive",
          "type": "boolean"
        },
        "infer_labels": {
          "default": false,
          "title": "Infer Labels",
          "type": "boolean"
        },
        "annotations_file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Annotations File"
        },
        "images_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Images Dir"
        },
        "labels_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Labels Dir"
        },
        "classes_file": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Classes File"
        }
      },
      "required": [
        "name",
        "format",
        "path"
      ],
      "title": "DatasetConfig",
      "type": "object"
    },
    "FlattenExtractorConfig": {
      "description": "FlattenExtractor configuration. No parameters.",
      "properties": {
        "type": {
          "const": "flatten",
          "default": "flatten",
          "title": "Type",
          "type": "string"
        }
      },
      "title": "FlattenExtractorConfig",
      "type": "object"
    },
    "LoggingConfig": {
      "description": "Logging level configuration.",
      "properties": {
        "app_level": {
          "default": "DEBUG",
          "enum": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR"
          ],
          "title": "App Level",
          "type": "string"
        },
        "lib_level": {
          "default": "WARNING",
          "enum": [
            "DEBUG",
            "INFO",
            "WARNING",
            "ERROR"
          ],
          "title": "Lib Level",
          "type": "string"
        }
      },
      "title": "LoggingConfig",
      "type": "object"
    },
    "ModelConfig": {
      "description": "Configuration for a model used for embedding extraction.",
      "properties": {
        "name": {
          "description": "Identifier for the model",
          "title": "Name",
          "type": "string"
        },
        "extractor": {
          "description": "Extractor configuration",
          "discriminator": {
            "mapping": {
              "bovw": "#/$defs/BoVWExtractorConfig",
              "flatten": "#/$defs/FlattenExtractorConfig",
              "onnx": "#/$defs/OnnxExtractorConfig",
              "torch": "#/$defs/TorchExtractorConfig",
              "uncertainty": "#/$defs/UncertaintyExtractorConfig"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/OnnxExtractorConfig"
            },
            {
              "$ref": "#/$defs/BoVWExtractorConfig"
            },
            {
              "$ref": "#/$defs/FlattenExtractorConfig"
            },
            {
              "$ref": "#/$defs/TorchExtractorConfig"
            },
            {
              "$ref": "#/$defs/UncertaintyExtractorConfig"
            }
          ],
          "title": "Extractor"
        }
      },
      "required": [
        "name",
        "extractor"
      ],
      "title": "ModelConfig",
      "type": "object"
    },
    "OnnxExtractorConfig": {
      "description": "OnnxExtractor configuration.",
      "properties": {
        "type": {
          "const": "onnx",
          "default": "onnx",
          "title": "Type",
          "type": "string"
        },
        "model_path": {
          "description": "Path to ONNX model file.",
          "title": "Model Path",
          "type": "string"
        },
        "output_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Output layer name. None = first output.",
          "title": "Output Name"
        },
        "flatten": {
          "default": true,
          "description": "Flatten output to (N, D) shape.",
          "title": "Flatten",
          "type": "boolean"
        }
      },
      "required": [
        "model_path"
      ],
      "title": "OnnxExtractorConfig",
      "type": "object"
    },
    "PreprocessingStep": {
      "description": "Single preprocessing step.\n\nPass-through to torchvision.transforms.v2 - any transform name is allowed.\nSee: https://pytorch.org/vision/stable/transforms.html\n\nExample\n-------\n>>> step = PreprocessingStep(step=\"Resize\", params={\"size\": 256, \"antialias\": True})\n>>> step = PreprocessingStep(step=\"Normalize\", params={\"mean\": [0.485], \"std\": [0.229]})",
      "properties": {
        "step": {
          "description": "Transform name from torchvision.transforms.v2",
          "title": "Step",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        }
      },
      "required": [
        "step"
      ],
      "title": "PreprocessingStep",
      "type": "object"
    },
    "PreprocessorConfig": {
      "description": "Named preprocessor pipeline configuration.\n\nUses existing PreprocessingStep which has 'step' field (not 'name').",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/PreprocessingStep"
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "name",
        "steps"
      ],
      "title": "PreprocessorConfig",
      "type": "object"
    },
    "SelectionConfig": {
      "description": "Named selection pipeline configuration.\n\nSimilar to PreprocessorConfig - defines reusable selection pipelines.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/SelectionStep"
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "name",
        "steps"
      ],
      "title": "SelectionConfig",
      "type": "object"
    },
    "SelectionStep": {
      "description": "Single selection step - pass-through to dataeval.selection.\n\nSee: https://dataeval.readthedocs.io/en/latest/reference/autoapi/dataeval/selection/index.html",
      "properties": {
        "type": {
          "description": "Selection class from dataeval.selection",
          "title": "Type",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        }
      },
      "required": [
        "type"
      ],
      "title": "SelectionStep",
      "type": "object"
    },
    "TaskConfig": {
      "description": "Task/workflow configuration schema.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "workflow": {
          "title": "Workflow",
          "type": "string"
        },
        "datasets": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ],
          "title": "Datasets"
        },
        "models": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Models"
        },
        "preprocessors": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Preprocessors"
        },
        "selections": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "additionalProperties": {
                "type": "string"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Selections"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        },
        "batch_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Batch Size"
        },
        "output_format": {
          "default": "json",
          "enum": [
            "json",
            "yaml",
            "text"
          ],
          "title": "Output Format",
          "type": "string"
        },
        "metadata_auto_bin_method": {
          "anyOf": [
            {
              "enum": [
                "uniform_width",
                "uniform_count",
                "clusters"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metadata Auto Bin Method"
        },
        "metadata_exclude": {
          "items": {
            "type": "string"
          },
          "title": "Metadata Exclude",
          "type": "array"
        },
        "metadata_continuous_factor_bins": {
          "anyOf": [
            {
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "items": {
                      "type": "number"
                    },
                    "type": "array"
                  }
                ]
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metadata Continuous Factor Bins"
        },
        "cache_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Directory for disk-backed computation cache. When set, expensive computations (embeddings, metadata, hash stats) are cached to disk and reused across runs. In containers, point to a mounted volume (e.g. /cache).",
          "title": "Cache Dir"
        }
      },
      "required": [
        "name",
        "workflow",
        "datasets"
      ],
      "title": "TaskConfig",
      "type": "object"
    },
    "TorchExtractorConfig": {
      "description": "TorchExtractor configuration.\n\nNote: model must be loadable from model_path (e.g., torchscript or\nstate_dict + class). Full programmatic model support deferred.",
      "properties": {
        "type": {
          "const": "torch",
          "default": "torch",
          "title": "Type",
          "type": "string"
        },
        "model_path": {
          "description": "Path to saved PyTorch model.",
          "title": "Model Path",
          "type": "string"
        },
        "layer_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Layer for forward hook extraction.",
          "title": "Layer Name"
        },
        "use_output": {
          "default": true,
          "description": "Capture layer output (True) or input (False).",
          "title": "Use Output",
          "type": "boolean"
        },
        "device": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Device (e.g., 'cpu', 'cuda:0').",
          "title": "Device"
        }
      },
      "required": [
        "model_path"
      ],
      "title": "TorchExtractorConfig",
      "type": "object"
    },
    "UncertaintyExtractorConfig": {
      "description": "ClassifierUncertaintyExtractor configuration.\n\nNote: same model_path constraint as TorchExtractorConfig.",
      "properties": {
        "type": {
          "const": "uncertainty",
          "default": "uncertainty",
          "title": "Type",
          "type": "string"
        },
        "model_path": {
          "description": "Path to saved classification model.",
          "title": "Model Path",
          "type": "string"
        },
        "preds_type": {
          "default": "probs",
          "description": "Model output format.",
          "enum": [
            "probs",
            "logits"
          ],
          "title": "Preds Type",
          "type": "string"
        },
        "batch_size": {
          "default": 32,
          "description": "Inference batch size.",
          "title": "Batch Size",
          "type": "integer"
        },
        "device": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Device (e.g., 'cpu', 'cuda:0').",
          "title": "Device"
        }
      },
      "required": [
        "model_path"
      ],
      "title": "UncertaintyExtractorConfig",
      "type": "object"
    }
  },
  "description": "Unified workflow configuration.\n\nOne optional field per registered workflow.",
  "properties": {
    "logging": {
      "anyOf": [
        {
          "$ref": "#/$defs/LoggingConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "data_cleaning": {
      "anyOf": [
        {
          "$ref": "#/$defs/DataCleaningParameters"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "models": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/ModelConfig"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional list of models for embedding extraction",
      "title": "Models"
    },
    "datasets": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/DatasetConfig"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Datasets"
    },
    "preprocessors": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/PreprocessorConfig"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Preprocessors"
    },
    "selections": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/SelectionConfig"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Selections"
    },
    "tasks": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/TaskConfig"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tasks"
    }
  },
  "title": "WorkflowConfig",
  "type": "object"
}