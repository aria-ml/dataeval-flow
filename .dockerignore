# =============================================================================
# Docker build context — only include what Dockerfiles actually COPY:
#   pyproject.toml, uv.lock, noxfile.py, src/, tests/, config/, entrypoint.sh, README.md
# =============================================================================

# Version control
.git
.gitattributes
.gitignore
.github

# CI/CD and Docker config (not needed inside images)
.gitlab-ci.yml
Dockerfile.*
docker/

# Python artifacts
.venv
.nox
__pycache__
*.pyc
*.pyo
*.egg-info
.coverage
.pytest_cache
.ruff_cache

# IDE and tooling
.claude
.vscode
.idea
*.swp
*.swo

# Environment and secrets
.env
.env.*
cosign.pub
cosign.key

# Documentation and metadata (not needed at runtime)
docs/
LICENSE
*.md
!README.md

# Build output
output/
htmlcov

# Local data (mounted at runtime, not baked in)
data/

# Misc
.cuda-version
